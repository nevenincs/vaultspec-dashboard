# =============================================================================
# vaultspec-dashboard environment variables
# =============================================================================
#
# Copy this file to `.env.local` and uncomment only the values you need.
#
# Installed commands:
#   vaultspec-dashboard
#
# =============================================================================


# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

# Workspace root directory the dashboard reads vault/spec state from.
# Inherits the vaultspec-core layout variables (VAULTSPEC_TARGET_DIR,
# VAULTSPEC_DOCS_DIR, VAULTSPEC_FRAMEWORK_DIR) when set.
# Type: Path | Default: current working directory
# VAULTSPEC_TARGET_DIR=.
