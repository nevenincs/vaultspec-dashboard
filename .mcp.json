{
  "mcpServers": {
    "vaultspec-core": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "vaultspec_core.mcp_server.app"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "figma": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "vaultspec-rag": {
      "command": "uv",
      "args": [
        "run",
        "vaultspec-search-mcp"
      ]
    }
  },
  "_vaultspecManaged": [
    "chrome-devtools",
    "figma",
    "playwright",
    "vaultspec-core",
    "vaultspec-rag"
  ]
}
