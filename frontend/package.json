{
  "name": "vaultspec-dashboard-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "vaultspec-dashboard SPA — decoupled web GUI served by the engine's serve mode (gui-spec §5)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src spike",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"spike/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"spike/**/*.ts\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "d3-ease": "^3.0.1",
    "d3-interpolate": "^3.0.1",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sigma": "^3.0.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
