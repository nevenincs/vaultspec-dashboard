{
  "name": "vaultspec-dashboard-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.5.2",
  "description": "vaultspec-dashboard SPA — decoupled web GUI served by the engine's serve mode (gui-spec §5)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src spike",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"spike/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"spike/**/*.ts\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "e2e": "playwright test",
    "tokens:build": "node style-dictionary.config.ts && prettier --write src/styles.css",
    "tokens:check": "node scripts/token-drift-check.ts",
    "tokens:figma": "node scripts/figma-export.ts",
    "figma:registry": "node scripts/figma-registry-check.ts",
    "figma:parity": "node scripts/figma-parity.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@pixi/react": "^8.0.5",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "d3-ease": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "lucide-react": "^1.18.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sigma": "^3.0.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-themes": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "culori": "^4.0.2",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.4",
    "storybook": "^10.4.5",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
