{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Primitive OKLCH ramps authored to match the binding Figma foundation while preserving the design-language ADR S01 generation mechanism. Intent-free lightness/chroma/hue stops; not the public surface. Color $value carries the OKLCH components; the optional hex sibling is the sRGB rendering used as the Figma/Style-Dictionary fallback and is regenerated by the OKLCH transform.",
  "primitive": {
    "neutral": {
      "$description": "Warm neutral ramp, hue 75deg, near-zero chroma: the ground and ink.",
      "0": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [1, 0, 75] } },
      "50": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.985, 0.006, 75] } },
      "100": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.968, 0.008, 75] } },
      "150": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.955, 0.009, 75] } },
      "200": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.928, 0.01, 75] } },
      "300": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.86, 0.011, 75] } },
      "400": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.72, 0.012, 75] } },
      "500": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.62, 0.012, 75] } },
      "600": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.53, 0.012, 75] } },
      "700": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.47, 0.013, 75] } },
      "800": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.38, 0.012, 75] } },
      "850": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.3, 0.011, 75] } },
      "900": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.235, 0.01, 75] } },
      "920": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.205, 0.009, 75] } },
      "940": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.185, 0.008, 75] } },
      "950": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.165, 0.008, 75] } },
      "980": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.13, 0.006, 75] } }
    },
    "accent": {
      "$description": "Earthy green accent ramp, hue 150deg: the single spent hue.",
      "300": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.945, 0.03, 150] } },
      "500": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.52, 0.08, 150] } },
      "600": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.38, 0.09, 150] } },
      "700": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.7, 0.09, 150] } },
      "800": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.8, 0.08, 150] } },
      "dark-subtle": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.3, 0.045, 150] } }
    },
    "tier": {
      "$description": "Four tier hues at fixed DISTINCT lightness, grayscale-safe by construction (S12). -l light rendering, -d dark rendering.",
      "declared-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.3, 0.012, 75], "hex": "#312d27" } },
      "structural-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.52, 0.09, 150], "hex": "#3f774d" } },
      "temporal-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.44, 0.03, 75], "hex": "#5c5040" } },
      "semantic-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.6, 0.07, 290] } },
      "declared-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.85, 0.01, 75], "hex": "#dbd7d0" } },
      "structural-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.72, 0.095, 150] } },
      "temporal-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.78, 0.03, 75] } },
      "semantic-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.7, 0.08, 290], "hex": "#6e659f" } }
    },
    "diff": {
      "$description": "Sacred diff hues, high-contrast in every theme (S13). -l light, -d dark.",
      "add-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.5, 0.13, 150] } },
      "remove-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.52, 0.16, 28] } },
      "modified-l": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.5, 0.13, 250] } },
      "add-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.72, 0.13, 150] } },
      "remove-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.68, 0.15, 28] } },
      "modified-d": { "$type": "color", "$value": { "colorSpace": "oklch", "components": [0.72, 0.13, 250] } }
    }
  }
}
